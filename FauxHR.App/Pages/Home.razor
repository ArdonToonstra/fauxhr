@page "/"
@using FauxHR.Core.Interfaces
@using FauxHR.Core.Services
@using Hl7.Fhir.Model
@inject IEnumerable<IIGModule> Modules
@inject NavigationManager NavManager
@inject AppState AppState
@implements IDisposable

<PageTitle>FauxHR - Dashboard</PageTitle>

<div class="container-fluid py-4">

    <!-- About FauxHR -->
    <div class="row mb-5">
        <div class="col-12">
            <h2 class="fw-light mb-3">What is FauxHR?</h2>
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="row g-4 align-items-center">
                        <div class="col-md-1 text-center">
                            <i class="bi bi-journal-medical display-4 text-primary"></i>
                        </div>
                        <div class="col-md-11">
                            <h5 class="fw-semibold mb-2">A fake EHR for testing FHIR Implementation Guides</h5>
                            <p class="text-muted mb-2">
                                FauxHR is a lightweight, simulated electronic health record designed to validate
                                <strong>FHIR Implementation Guides (IGs)</strong> by actually implementing them.
                                Rather than testing conformance in isolation, FauxHR gives you a realistic EHR
                                context — a patient, a practitioner, a FHIR server — so you can exercise each
                                IG's workflows end-to-end.
                            </p>
                            <p class="text-muted mb-0">
                                Each <strong>component</strong> below implements one IG. Select a patient via the
                                top-right corner, then open a component to start testing.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modules Section -->
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-light">Components</h2>
            <p class="text-muted">Select a module for the current context.</p>
            @if (!string.IsNullOrEmpty(feedbackMessage))
            {
                <div class="alert @feedbackClass py-2">@feedbackMessage</div>
            }
        </div>
    </div>

    <div class="row g-4">
        @foreach (var module in Modules)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card h-100 module-card @(CurrentPatient == null ? "disabled" : "")" @onclick="() => NavigateToModule(module)">
                    <div class="card-body text-center d-flex flex-column align-items-center justify-content-center p-5">
                        <div class="icon-wrapper mb-4">
                            <i class="@module.IconClass display-4"></i>
                        </div>
                        <h5 class="card-title fw-normal">@module.Title</h5>
                        <p class="card-text text-muted small mt-2">@module.Description</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private Patient? CurrentPatient => AppState.CurrentPatient;

    private string feedbackMessage = "";
    private string feedbackClass = "";

    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }

    private void NavigateToModule(IIGModule module)
    {
        if (CurrentPatient == null)
        {
            feedbackMessage = "Please select a patient first.";
            feedbackClass = "alert-warning";
            return;
        }
        NavManager.NavigateTo(module.EntryPath);
    }
}
