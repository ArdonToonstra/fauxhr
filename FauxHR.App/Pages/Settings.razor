@page "/settings"
@using FauxHR.Core.Services
@using FauxHR.Core.Interfaces
@inject AppState AppState
@inject IFhirService FhirService
@implements IDisposable

<PageTitle>FauxHR - Settings</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-light">Settings</h2>
            <p class="text-muted">Configure your environment.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title mb-3">FHIR Servers</h5>

                    @{
                        var _cfg = AppState.CurrentServerConfig;
                        var _proxyActive = AppState.UseServerProxy;
                        var _proxyMissing = (_cfg?.RequiresProxy ?? false) && !AppState.IsServerProxyAvailable;
                    }
                    @if (_proxyActive)
                    {
                        <div class="alert alert-success py-2" role="alert">
                            <i class="bi bi-shield-check me-1"></i>
                            <strong>Proxy active.</strong> Requests are routed server-to-server, bypassing CORS and certificate issues.
                        </div>
                    }
                    else if (_proxyMissing && (_cfg?.HasUntrustedCert ?? false))
                    {
                        <div class="alert alert-warning" role="alert">
                            <strong><i class="bi bi-shield-exclamation me-1"></i> Certificate Acceptance Required</strong>
                            <p class="mb-2 mt-2">
                                This server uses a certificate from a private CA that browsers do not trust by default.
                                Before making requests, open the link below, accept the browser's certificate warning, then return here.
                            </p>
                            <a href="@(_cfg!.Url.TrimEnd('/') + "/metadata")" target="_blank" rel="noopener noreferrer"
                               class="btn btn-sm btn-outline-warning mb-2">
                                <i class="bi bi-box-arrow-up-right me-1"></i> Open &amp; Accept Certificate
                            </a>
                            <p class="mb-0 small text-muted">
                                For a seamless experience without manual cert acceptance, use
                                <a href="https://fauxhr.donit.be" target="_blank">fauxhr.donit.be</a>
                                where the server proxy handles this automatically.
                            </p>
                        </div>
                    }
                    else if (_proxyMissing)
                    {
                        <div class="alert alert-warning" role="alert">
                            <strong><i class="bi bi-exclamation-triangle-fill"></i> Server Proxy Not Running</strong>
                            <p class="mb-2 mt-2">This server requires the <strong>FauxHR.App.Server</strong> project to be running. Requests are routed through a local reverse proxy to bypass CORS restrictions.</p>
                            <p class="mb-2"><strong>Run locally:</strong></p>
                            <code class="d-block bg-dark text-white p-2 rounded small">dotnet run --project FauxHR.App.Server</code>
                            <p class="mb-0 mt-2 small">Alternatively, use the hosted version at <a href="https://fauxhr.donit.be" target="_blank">fauxhr.donit.be</a> which has the proxy built in.</p>
                        </div>
                    }

                    <div class="list-group mb-3">
                        @foreach (var server in AppState.AvailableServers)
                        {
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-bold">
                                            @server.Label
                                            @if (server.RequiresProxy)
                                            {
                                                <span class="badge bg-info-subtle text-info ms-1" title="Requests proxied through FauxHR.App.Server">Proxy</span>
                                            }
                                        </div>
                                        <div class="small text-muted">@server.Url</div>
                                    </div>
                                    <div>
                                        @if(server.Url == AppState.CurrentServerUrl)
                                        {
                                            <span class="badge bg-success me-2">Active</span>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => SetActiveServer(server.Url)">Use</button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveServer(server.Url)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleServerHeaders(server.Url)" title="Configure headers">
                                            <i class="bi bi-gear"></i>
                                        </button>
                                    </div>
                                </div>

                                @if (expandedServerUrl == server.Url)
                                {
                                    <div class="mt-3 pt-3 border-top">
                                        <label class="form-label small fw-bold">Custom HTTP Headers</label>
                                        @if (editingHeaders.Any())
                                        {
                                            <div class="table-responsive mb-2">
                                                <table class="table table-sm table-bordered mb-0">
                                                    <thead class="table-light">
                                                        <tr>
                                                            <th>Header</th>
                                                            <th>Value</th>
                                                            <th style="width: 40px;"></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var header in editingHeaders)
                                                        {
                                                            <tr>
                                                                <td><input type="text" class="form-control form-control-sm border-0" @bind="header.Key" placeholder="Key" /></td>
                                                                <td><input type="text" class="form-control form-control-sm border-0" @bind="header.Value" placeholder="Value" /></td>
                                                                <td class="text-center">
                                                                    <button class="btn btn-link link-danger p-0" @onclick="() => editingHeaders.Remove(header)">
                                                                        <i class="bi bi-x-lg"></i>
                                                                    </button>
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                        <div class="d-flex justify-content-between">
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => editingHeaders.Add(new HeaderItem())">
                                                <i class="bi bi-plus-lg me-1"></i> Add Header
                                            </button>
                                            <button class="btn btn-sm btn-primary" @onclick="() => SaveServerHeaders(server.Url)">
                                                Save
                                            </button>
                                        </div>
                                        @if (headerSavedForUrl == server.Url)
                                        {
                                            <span class="text-success small mt-1 d-block">Saved!</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="border-top pt-3">
                        <label class="form-label small fw-bold">Add New Server</label>
                        <div class="row g-2">
                            <div class="col-4">
                                <input type="text" class="form-control form-control-sm" placeholder="Label" @bind="newServerLabel" />
                            </div>
                            <div class="col-6">
                                <input type="text" class="form-control form-control-sm" placeholder="https://..." @bind="newServerUrl" />
                            </div>
                            <div class="col-2">
                                <button class="btn btn-sm btn-secondary w-100" @onclick="AddServer">Add</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title mb-3">Debug Tools</h5>
                    <p class="card-text">Quickly load test data.</p>

                    <button class="btn btn-outline-primary mb-2" @onclick="LoadDefaultPatient" disabled="@isLoading">
                        @if(isLoading) { <span>Loading...</span> } else { <span>Load "Hendrik Hartman"</span> }
                    </button>

                    @if (!string.IsNullOrEmpty(loadMessage))
                    {
                        <div class="mt-2 text-small @messageClass">
                            @loadMessage
                        </div>
                    }

                    <div class="border-top pt-3 mt-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="showDebugInfo"
                                   checked="@AppState.ShowDebugInfo"
                                   @onchange="@(e => AppState.SetShowDebugInfo((bool)e.Value!))" />
                            <label class="form-check-label" for="showDebugInfo">Enable Debug Mode (Show JSON)</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title mb-3">Reference Resolution</h5>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="enableReferences"
                                   @bind="enableReferences" />
                            <label class="form-check-label" for="enableReferences">
                                Enable automatic reference resolution
                            </label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Resolution Depth: @resolutionDepth level(s)</label>
                        <input type="range" class="form-range" min="1" max="5"
                               @bind="resolutionDepth" @bind:event="oninput"
                               disabled="@(!enableReferences)" />
                        <div class="form-text">
                            Level 1: Direct references only. Level 3 (recommended).
                        </div>
                    </div>

                    <button class="btn btn-primary" @onclick="SaveReferenceSettings">Save Settings</button>
                    @if (referenceSaved)
                    {
                        <span class="text-success ms-2 fade-in">Saved!</span>
                    }
                </div>
            </div>
        </div>

        <!-- Last Request / Response -->
        <div class="col-md-6 mt-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title mb-3">Last Request / Response</h5>

                    @if (AppState.LastRequestLog != null)
                    {
                        var log = AppState.LastRequestLog;
                        <div class="small mb-2 text-muted">@log.Timestamp.ToString("HH:mm:ss")</div>

                        <div class="mb-2">
                            <span class="badge @(log.StatusCode < 300 ? "bg-success" : "bg-danger") me-1">@log.StatusCode</span>
                            <span class="badge bg-secondary me-1">@log.Method</span>
                        </div>

                        <div class="mb-2">
                            <label class="form-label small fw-bold mb-1">URL</label>
                            <pre class="bg-light border rounded p-2 small mb-0" style="white-space: pre-wrap; word-break: break-all; max-height: 60px; overflow: auto;">@log.Url</pre>
                        </div>

                        <div class="mb-2">
                            <label class="form-label small fw-bold mb-1">Request Headers</label>
                            <pre class="bg-light border rounded p-2 small mb-0" style="max-height: 120px; overflow: auto;">@FormatHeaders(log.RequestHeaders)</pre>
                        </div>

                        @if (AppState.ShowDebugInfo)
                        {
                            <div>
                                <label class="form-label small fw-bold mb-1">Response Body</label>
                                <pre class="bg-light border rounded p-2 small mb-0" style="max-height: 300px; overflow: auto;">@log.ResponseBody</pre>
                            </div>
                        }
                        else
                        {
                            <div class="small text-muted">
                                <i class="bi bi-info-circle me-1"></i>
                                Enable Debug Mode above to see the response body.
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted small mb-0">No requests made yet.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6 mt-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title mb-3">Conformance Testing</h5>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" id="conformanceMode"
                               checked="@conformanceMode"
                               @onchange="@(e => { conformanceMode = (bool)e.Value!; AppState.SetConformanceTestingMode(conformanceMode); })" />
                        <label class="form-check-label" for="conformanceMode">
                            Enable Conformance Testing Mode
                        </label>
                    </div>

                    @if (conformanceMode)
                    {
                        <div class="alert alert-info small mb-0">
                            <i class="bi bi-info-circle me-1"></i>
                            Per-server headers (configured above via <i class="bi bi-gear"></i>) are injected into all outgoing FHIR requests.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string newServerLabel = "";
    private string newServerUrl = "";

    private bool isLoading = false;
    private bool referenceSaved = false;
    private string loadMessage = "";
    private string messageClass = "";

    private bool enableReferences = true;
    private int resolutionDepth = 3;

    // Conformance Settings
    private bool conformanceMode = true;

    // Per-server header editing
    private string? expandedServerUrl;
    private List<HeaderItem> editingHeaders = new();
    private string? headerSavedForUrl;

    protected override void OnInitialized()
    {
        enableReferences = AppState.EnableReferenceResolution;
        resolutionDepth = AppState.ReferenceResolutionDepth;
        conformanceMode = AppState.ConformanceTestingMode;
        AppState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }

    private string FormatHeaders(Dictionary<string, string> headers)
        => string.Join("\n", headers.Select(h => $"{h.Key}: {h.Value}"));

    private void ToggleServerHeaders(string serverUrl)
    {
        if (expandedServerUrl == serverUrl)
        {
            expandedServerUrl = null;
            return;
        }
        expandedServerUrl = serverUrl;
        headerSavedForUrl = null;
        var server = AppState.AvailableServers.FirstOrDefault(s => s.Url == serverUrl);
        editingHeaders = server?.CustomHeaders.Select(h => new HeaderItem { Key = h.Key, Value = h.Value }).ToList() ?? new();
    }

    private void SaveServerHeaders(string serverUrl)
    {
        var validHeaders = editingHeaders.Where(h => !string.IsNullOrWhiteSpace(h.Key)).ToList();
        AppState.UpdateServerHeaders(serverUrl, validHeaders);
        headerSavedForUrl = serverUrl;
        Task.Delay(2000).ContinueWith(_ => InvokeAsync(() => { headerSavedForUrl = null; StateHasChanged(); }));
    }

    private void SaveReferenceSettings()
    {
        AppState.SetReferenceResolutionSettings(enableReferences, resolutionDepth);
        referenceSaved = true;
        Task.Delay(2000).ContinueWith(_ => InvokeAsync(() => { referenceSaved = false; StateHasChanged(); }));
    }

    private void AddServer()
    {
        if (!string.IsNullOrWhiteSpace(newServerUrl) && !string.IsNullOrWhiteSpace(newServerLabel))
        {
            AppState.AddServer(newServerUrl, newServerLabel);
            newServerUrl = "";
            newServerLabel = "";
        }
    }

    private void RemoveServer(string url)
    {
        AppState.RemoveServer(url);
    }

    private void SetActiveServer(string url)
    {
        AppState.SetServerUrl(url);
    }

    private async Task LoadDefaultPatient()
    {
        isLoading = true;
        loadMessage = "";
        try
        {
            var patient = await FhirService.SearchPatientByIdentifierAsync("http://fhir.nl/fhir/NamingSystem/bsn", "999911120");

            if (patient != null)
            {
                AppState.SetPatient(patient);
                loadMessage = "Patient loaded successfully!";
                messageClass = "text-success";
            }
            else
            {
                loadMessage = "Patient not found on this server.";
                messageClass = "text-danger";
            }
        }
        catch (Exception ex)
        {
            loadMessage = $"Error: {ex.Message}";
            messageClass = "text-danger";
        }
        finally
        {
            isLoading = false;
        }
    }
}
