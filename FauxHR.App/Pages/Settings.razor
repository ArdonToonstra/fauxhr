@page "/settings"
@using FauxHR.Core.Services
@using FauxHR.Core.Interfaces
@using System.Text.Json
@using System.Text.Json.Serialization
@using Hl7.Fhir.Serialization
@using Hl7.Fhir.Model
@using Task = System.Threading.Tasks.Task
@inject AppState AppState
@inject IFhirService FhirService
@inject HttpClient Http
@implements IDisposable

<PageTitle>FauxHR - Settings</PageTitle>

<div class="container-fluid py-4">

    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-light">Settings</h2>
            <p class="text-muted">Configure your environment.</p>
        </div>
    </div>

    <!-- ── FHIR Server ──────────────────────────────────────────────────── -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3">
                        <i class="bi bi-hdd-network me-2 text-primary"></i>FHIR Server
                    </h5>

                    @{
                        var _cfg = AppState.CurrentServerConfig;
                        var _proxyActive = AppState.UseServerProxy;
                        var _proxyMissing = (_cfg?.RequiresProxy ?? false) && !AppState.IsServerProxyAvailable;
                    }
                    @if (_proxyActive)
                    {
                        <div class="alert alert-success py-2 mb-3" role="alert">
                            <i class="bi bi-shield-check me-1"></i>
                            <strong>Proxy active.</strong> Requests are routed server-to-server, bypassing CORS and certificate issues.
                        </div>
                    }
                    else if (_proxyMissing && (_cfg?.HasUntrustedCert ?? false))
                    {
                        <div class="alert alert-warning mb-3" role="alert">
                            <strong><i class="bi bi-shield-exclamation me-1"></i> Certificate Acceptance Required</strong>
                            <p class="mb-2 mt-2">
                                This server uses a certificate from a private CA that browsers do not trust by default.
                                Before making requests, open the link below, accept the browser's certificate warning, then return here.
                            </p>
                            <a href="@(_cfg!.Url.TrimEnd('/') + "/metadata")" target="_blank" rel="noopener noreferrer"
                               class="btn btn-sm btn-outline-warning mb-2">
                                <i class="bi bi-box-arrow-up-right me-1"></i> Open &amp; Accept Certificate
                            </a>
                            <p class="mb-0 small text-muted">
                                For a seamless experience without manual cert acceptance, use
                                <a href="https://fauxhr.donit.be" target="_blank">fauxhr.donit.be</a>
                                where the server proxy handles this automatically.
                            </p>
                        </div>
                    }
                    else if (_proxyMissing)
                    {
                        <div class="alert alert-warning mb-3" role="alert">
                            <strong><i class="bi bi-exclamation-triangle-fill"></i> Server Proxy Not Running</strong>
                            <p class="mb-2 mt-2">This server requires the <strong>FauxHR.App.Server</strong> project to be running. Requests are routed through a local reverse proxy to bypass CORS restrictions.</p>
                            <p class="mb-2"><strong>Run locally:</strong></p>
                            <code class="d-block bg-dark text-white p-2 rounded small">dotnet run --project FauxHR.App.Server</code>
                            <p class="mb-0 mt-2 small">Alternatively, use the hosted version at <a href="https://fauxhr.donit.be" target="_blank">fauxhr.donit.be</a> which has the proxy built in.</p>
                        </div>
                    }

                    <div class="list-group mb-3">
                        @foreach (var server in AppState.AvailableServers)
                        {
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-semibold">
                                            @server.Label
                                            @if (server.RequiresProxy)
                                            {
                                                <span class="badge bg-info-subtle text-info ms-1" title="Requests proxied through FauxHR.App.Server">Proxy</span>
                                            }
                                        </div>
                                        <div class="small text-muted">@server.Url</div>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        @if (server.Url == AppState.CurrentServerUrl)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => SetActiveServer(server.Url)">Use</button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveServer(server.Url)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleServerHeaders(server.Url)" title="Custom HTTP headers">
                                            <i class="bi bi-gear"></i>
                                        </button>
                                    </div>
                                </div>

                                @if (expandedServerUrl == server.Url)
                                {
                                    <div class="mt-3 pt-3 border-top">
                                        <label class="form-label small fw-bold">Custom HTTP Headers</label>
                                        @if (editingHeaders.Any())
                                        {
                                            <div class="table-responsive mb-2">
                                                <table class="table table-sm table-bordered mb-0">
                                                    <thead class="table-light">
                                                        <tr>
                                                            <th>Header</th>
                                                            <th>Value</th>
                                                            <th style="width: 40px;"></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var header in editingHeaders)
                                                        {
                                                            <tr>
                                                                <td><input type="text" class="form-control form-control-sm border-0" @bind="header.Key" placeholder="Key" /></td>
                                                                <td><input type="text" class="form-control form-control-sm border-0" @bind="header.Value" placeholder="Value" /></td>
                                                                <td class="text-center">
                                                                    <button class="btn btn-link link-danger p-0" @onclick="() => editingHeaders.Remove(header)">
                                                                        <i class="bi bi-x-lg"></i>
                                                                    </button>
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                        <div class="d-flex justify-content-between">
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => editingHeaders.Add(new HeaderItem())">
                                                <i class="bi bi-plus-lg me-1"></i> Add Header
                                            </button>
                                            <button class="btn btn-sm btn-primary" @onclick="() => SaveServerHeaders(server.Url)">
                                                Save
                                            </button>
                                        </div>
                                        @if (headerSavedForUrl == server.Url)
                                        {
                                            <span class="text-success small mt-1 d-block">Saved!</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="border-top pt-3 mb-4">
                        <label class="form-label small fw-bold">Add Server</label>
                        <div class="row g-2">
                            <div class="col-4">
                                <input type="text" class="form-control form-control-sm" placeholder="Label" @bind="newServerLabel" />
                            </div>
                            <div class="col-6">
                                <input type="text" class="form-control form-control-sm" placeholder="https://..." @bind="newServerUrl" />
                            </div>
                            <div class="col-2">
                                <button class="btn btn-sm btn-secondary w-100" @onclick="AddServer">Add</button>
                            </div>
                        </div>
                    </div>

                    <!-- Conformance Testing — integrated as server card footer -->
                    <div class="border-top pt-3 d-flex align-items-start justify-content-between gap-3">
                        <div>
                            <div class="fw-semibold small mb-1">
                                <i class="bi bi-shield-check me-1 text-secondary"></i>Conformance Testing Mode
                            </div>
                            <div class="text-muted small">
                                When enabled, custom headers (configure via <i class="bi bi-gear"></i>) are injected into all outgoing FHIR requests.
                            </div>
                        </div>
                        <div class="form-check form-switch flex-shrink-0 mb-0 pt-1">
                            <input class="form-check-input" type="checkbox" id="conformanceMode"
                                   checked="@conformanceMode"
                                   @onchange="@(e => { conformanceMode = (bool)e.Value!; AppState.SetConformanceTestingMode(conformanceMode); })" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Seed Data + Developer Tools ──────────────────────────────────── -->
    <div class="row g-4 align-items-start">

        <!-- Seed Data (left) -->
        <div class="col-lg-7">
            <h5 class="fw-semibold mb-3">
                <i class="bi bi-database-up me-2 text-primary"></i>Seed Data
            </h5>
            <p class="text-muted small mb-3">
                POST transaction bundles to <strong>@(AppState.CurrentServerConfig?.Label ?? "the active server")</strong>.
                Add bundles by committing JSON files and updating <code>wwwroot/seed-data/index.json</code>.
            </p>

            @if (manifestLoading)
            {
                <div class="text-muted small py-2">
                    <span class="spinner-border spinner-border-sm me-2"></span>Loading manifest...
                </div>
            }
            else if (manifestError != null)
            {
                <div class="alert alert-danger small py-2">
                    <i class="bi bi-exclamation-circle me-1"></i>@manifestError
                </div>
            }
            else if (!seedBundles.Any())
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-muted small p-4">
                        <i class="bi bi-inbox me-2"></i>No bundles in <code>wwwroot/seed-data/index.json</code> yet.
                        See <code>wwwroot/seed-data/README.md</code> for instructions.
                    </div>
                </div>
            }
            else
            {
                @foreach (var group in seedBundles.GroupBy(b => b.ModuleName))
                {
                    <h6 class="text-uppercase text-muted small fw-bold mb-2">@group.Key</h6>
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="list-group list-group-flush rounded">
                            @foreach (var bundle in group)
                            {
                                var result = bundleResults.TryGetValue(bundle.Id, out var r) ? r : null;
                                var posting = postingIds.Contains(bundle.Id);
                                <div class="list-group-item d-flex align-items-center gap-3 py-3">
                                    <div class="flex-grow-1 min-width-0">
                                        <div class="fw-semibold small">@bundle.Name</div>
                                        @if (!string.IsNullOrEmpty(bundle.Description))
                                        {
                                            <div class="text-muted" style="font-size: 0.8rem;">@bundle.Description</div>
                                        }
                                    </div>
                                    @if (result != null)
                                    {
                                        @if (result.IsSuccess)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle text-nowrap">
                                                <i class="bi bi-check-lg me-1"></i>@result.Message
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle text-nowrap" title="@result.Message">
                                                <i class="bi bi-x-lg me-1"></i>Error
                                            </span>
                                        }
                                    }
                                    <button class="btn btn-sm btn-outline-primary flex-shrink-0"
                                            @onclick="() => PostBundle(bundle)"
                                            disabled="@posting">
                                        @if (posting)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-cloud-upload me-1"></i>
                                        }
                                        POST
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Developer Tools (right) -->
        <div class="col-lg-5">

            <!-- Last Request — first-class panel -->
            @{
                var log = AppState.LastRequestLog;
                var logSuccess = log != null && log.StatusCode < 300;
                var logColor = log == null ? "secondary" : (logSuccess ? "success" : "danger");
            }
            <div class="card border-0 shadow-sm mb-4 overflow-hidden">
                <div class="card-header bg-body border-bottom d-flex align-items-center justify-content-between py-2 px-3">
                    <span class="fw-semibold small">
                        <i class="bi bi-activity me-2 text-@logColor"></i>Last Request
                    </span>
                    @if (log != null)
                    {
                        <span class="text-muted" style="font-size: 0.75rem;">@log.Timestamp.ToString("HH:mm:ss")</span>
                    }
                    @if (postingIds.Any())
                    {
                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle ms-auto">
                            <span class="spinner-border spinner-border-sm me-1" style="width:.6rem;height:.6rem;"></span>in flight
                        </span>
                    }
                </div>

                @if (log != null)
                {
                    <div class="px-3 py-2 bg-@logColor-subtle border-bottom d-flex align-items-center gap-2 flex-wrap">
                        <span class="badge bg-@logColor">@log.StatusCode</span>
                        <span class="badge bg-secondary">@log.Method</span>
                        <span class="text-muted font-monospace text-truncate small flex-fill" style="min-width: 0;" title="@log.Url">@log.Url</span>
                    </div>

                    <div class="px-3 pt-3 pb-2">
                        <div class="text-uppercase text-muted fw-bold mb-1" style="font-size: 0.7rem;">URL</div>
                        <pre class="bg-light border rounded p-2 small mb-0" style="white-space: pre-wrap; word-break: break-all; max-height: 56px; overflow: auto;">@log.Url</pre>
                    </div>

                    <div class="px-3 py-2">
                        <div class="text-uppercase text-muted fw-bold mb-1" style="font-size: 0.7rem;">Request Headers</div>
                        <pre class="bg-light border rounded p-2 small mb-0" style="max-height: 100px; overflow: auto;">@FormatHeaders(log.RequestHeaders)</pre>
                    </div>

                    @if (AppState.ShowDebugInfo)
                    {
                        <div class="px-3 pb-3 pt-2 border-top">
                            <div class="text-uppercase text-muted fw-bold mb-1" style="font-size: 0.7rem;">Response Body</div>
                            <pre class="bg-light border rounded p-2 small mb-0" style="max-height: 300px; overflow: auto;">@log.ResponseBody</pre>
                        </div>
                    }
                    else
                    {
                        <div class="px-3 pb-3 pt-2 border-top">
                            <span class="text-muted small">
                                <i class="bi bi-info-circle me-1"></i>Enable Debug Mode below to see the response body.
                            </span>
                        </div>
                    }
                }
                else
                {
                    <div class="px-3 py-4 text-muted small text-center">
                        <i class="bi bi-hourglass me-1"></i>No requests yet — use the app or POST a seed bundle.
                    </div>
                }
            </div>

            <!-- Developer Options -->
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="fw-semibold mb-3">
                        <i class="bi bi-tools me-2 text-secondary"></i>Developer Options
                    </h6>

                    <!-- Debug Mode -->
                    <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
                        <div>
                            <div class="fw-semibold small">Debug Mode</div>
                            <div class="text-muted" style="font-size: 0.8rem;">Show full response JSON in the request panel above.</div>
                        </div>
                        <div class="form-check form-switch flex-shrink-0 mb-0 pt-1">
                            <input class="form-check-input" type="checkbox" id="showDebugInfo"
                                   checked="@AppState.ShowDebugInfo"
                                   @onchange="@(e => AppState.SetShowDebugInfo((bool)e.Value!))" />
                        </div>
                    </div>

                    <!-- Load Test Patient -->
                    <div class="border-top pt-3 mb-3">
                        <div class="fw-semibold small mb-1">Load Test Patient</div>
                        <div class="text-muted mb-2" style="font-size: 0.8rem;">Quickly set Hendrik Hartman as the active patient from the current server.</div>
                        <button class="btn btn-sm btn-outline-primary" @onclick="LoadDefaultPatient" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            else
                            {
                                <i class="bi bi-person-check me-1"></i>
                            }
                            Load Hendrik Hartman
                        </button>
                        @if (!string.IsNullOrEmpty(loadMessage))
                        {
                            <div class="mt-2 small @messageClass">@loadMessage</div>
                        }
                    </div>

                    <!-- Reference Resolution -->
                    <div class="border-top pt-3">
                        <div class="fw-semibold small mb-2">Reference Resolution</div>
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="enableReferences" @bind="enableReferences" />
                            <label class="form-check-label small" for="enableReferences">Resolve references automatically</label>
                        </div>
                        @if (enableReferences)
                        {
                            <label class="form-label small text-muted mb-1">Depth: @resolutionDepth level(s)</label>
                            <input type="range" class="form-range mb-2" min="1" max="5"
                                   @bind="resolutionDepth" @bind:event="oninput" />
                            <div class="form-text mt-0 mb-2">Level 1: direct references only. Level 3 recommended.</div>
                        }
                        <button class="btn btn-sm btn-primary" @onclick="SaveReferenceSettings">Save</button>
                        @if (referenceSaved)
                        {
                            <span class="text-success ms-2 small fade-in">Saved!</span>
                        }
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

@code {
    private string newServerLabel = "";
    private string newServerUrl = "";

    private bool isLoading = false;
    private bool referenceSaved = false;
    private string loadMessage = "";
    private string messageClass = "";

    private bool enableReferences = true;
    private int resolutionDepth = 3;
    private bool conformanceMode = true;

    private string? expandedServerUrl;
    private List<HeaderItem> editingHeaders = new();
    private string? headerSavedForUrl;

    protected override async Task OnInitializedAsync()
    {
        enableReferences = AppState.EnableReferenceResolution;
        resolutionDepth = AppState.ReferenceResolutionDepth;
        conformanceMode = AppState.ConformanceTestingMode;
        AppState.OnChange += StateHasChanged;
        await LoadManifest();
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }

    private string FormatHeaders(Dictionary<string, string> headers)
        => string.Join("\n", headers.Select(h => $"{h.Key}: {h.Value}"));

    private void ToggleServerHeaders(string serverUrl)
    {
        if (expandedServerUrl == serverUrl)
        {
            expandedServerUrl = null;
            return;
        }
        expandedServerUrl = serverUrl;
        headerSavedForUrl = null;
        var server = AppState.AvailableServers.FirstOrDefault(s => s.Url == serverUrl);
        editingHeaders = server?.CustomHeaders.Select(h => new HeaderItem { Key = h.Key, Value = h.Value }).ToList() ?? new();
    }

    private void SaveServerHeaders(string serverUrl)
    {
        var validHeaders = editingHeaders.Where(h => !string.IsNullOrWhiteSpace(h.Key)).ToList();
        AppState.UpdateServerHeaders(serverUrl, validHeaders);
        headerSavedForUrl = serverUrl;
        Task.Delay(2000).ContinueWith(_ => InvokeAsync(() => { headerSavedForUrl = null; StateHasChanged(); }));
    }

    private void SaveReferenceSettings()
    {
        AppState.SetReferenceResolutionSettings(enableReferences, resolutionDepth);
        referenceSaved = true;
        Task.Delay(2000).ContinueWith(_ => InvokeAsync(() => { referenceSaved = false; StateHasChanged(); }));
    }

    private void AddServer()
    {
        if (!string.IsNullOrWhiteSpace(newServerUrl) && !string.IsNullOrWhiteSpace(newServerLabel))
        {
            AppState.AddServer(newServerUrl, newServerLabel);
            newServerUrl = "";
            newServerLabel = "";
        }
    }

    private void RemoveServer(string url) => AppState.RemoveServer(url);
    private void SetActiveServer(string url) => AppState.SetServerUrl(url);

    private async Task LoadDefaultPatient()
    {
        isLoading = true;
        loadMessage = "";
        try
        {
            var patient = await FhirService.SearchPatientByIdentifierAsync("http://fhir.nl/fhir/NamingSystem/bsn", "999911120");
            if (patient != null)
            {
                AppState.SetPatient(patient);
                loadMessage = "Patient loaded successfully!";
                messageClass = "text-success";
            }
            else
            {
                loadMessage = "Patient not found on this server.";
                messageClass = "text-danger";
            }
        }
        catch (Exception ex)
        {
            loadMessage = $"Error: {ex.Message}";
            messageClass = "text-danger";
        }
        finally { isLoading = false; }
    }

    // ── Seed Data ────────────────────────────────────────────────────────────

    private bool manifestLoading = true;
    private string? manifestError;
    private List<SeedBundleInfo> seedBundles = new();
    private Dictionary<string, BundlePostResult> bundleResults = new();
    private HashSet<string> postingIds = new();

    private async Task LoadManifest()
    {
        manifestLoading = true;
        manifestError = null;
        try
        {
            var manifest = await Http.GetFromJsonAsync<SeedManifest>("seed-data/index.json");
            seedBundles = manifest?.Bundles ?? new();
        }
        catch (Exception ex)
        {
            manifestError = $"Could not load seed-data/index.json: {ex.Message}";
        }
        finally { manifestLoading = false; }
    }

    private async Task PostBundle(SeedBundleInfo info)
    {
        postingIds.Add(info.Id);
        bundleResults.Remove(info.Id);
        StateHasChanged();
        try
        {
            var json = await Http.GetStringAsync(info.File);
            var bundle = new FhirJsonDeserializer().Deserialize<Bundle>(json);
            var response = await FhirService.TransactionAsync(bundle);

            var entries = response.Entry ?? new();
            var succeeded = entries.Count(e =>
                e.Response?.Status != null && e.Response.Status.StartsWith("2"));
            var failed = entries.Count - succeeded;

            bundleResults[info.Id] = failed == 0
                ? new BundlePostResult { IsSuccess = true, Message = $"{succeeded} resource{(succeeded == 1 ? "" : "s")}" }
                : new BundlePostResult { IsSuccess = false, Message = $"{failed} of {entries.Count} failed" };
        }
        catch (Exception ex)
        {
            bundleResults[info.Id] = new BundlePostResult { IsSuccess = false, Message = ex.Message };
        }
        finally
        {
            postingIds.Remove(info.Id);
            StateHasChanged();
        }
    }

    private class SeedManifest
    {
        [JsonPropertyName("bundles")]
        public List<SeedBundleInfo> Bundles { get; set; } = new();
    }

    private class SeedBundleInfo
    {
        [JsonPropertyName("id")]    public string Id { get; set; } = "";
        [JsonPropertyName("name")] public string Name { get; set; } = "";
        [JsonPropertyName("description")] public string Description { get; set; } = "";
        [JsonPropertyName("module")] public string Module { get; set; } = "";
        [JsonPropertyName("moduleName")] public string ModuleName { get; set; } = "";
        [JsonPropertyName("file")]  public string File { get; set; } = "";
    }

    private class BundlePostResult
    {
        public bool IsSuccess { get; init; }
        public string Message { get; init; } = "";
    }
}
